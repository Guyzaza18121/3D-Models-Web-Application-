# ──────────────────────────────────────────────────────────────────────────────
# FOSTEC FIM 4.0 — Environment Configuration
# Copy to .env.local and fill in values
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (Express server)
# Required for auth, config persistence, and command forwarding
VITE_API_URL=http://localhost:5000

# Simulation mode — set "true" ONLY for frontend dev without backend
# Default is "false" to prefer real data (Node-RED / MQTT)
VITE_SIMULATION_MODE=false

# JWT token storage key (must match backend config)
VITE_TOKEN_KEY=fim_token

# ── MQTT / Node-RED Telemetry ────────────────────────────────────────────────
# When VITE_MQTT_BROKER is set, frontend connects directly to MQTT
# for real-time sensor / compressor telemetry from Node-RED
# VITE_MQTT_BROKER=ws://localhost:1884
# VITE_MQTT_TOPIC_PREFIX=fostec
