PORT=5000
MONGODB_URI=mongodb://localhost:27017/fostec_fim
JWT_SECRET=fostec_fim_secret_change_in_production
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000

# MQTT broker for Node-RED integration
# Leave empty to disable MQTT (backend stores state in MongoDB only)
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=fostec
